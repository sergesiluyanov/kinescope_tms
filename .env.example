# Скопируйте этот файл в .env и подставьте реальные значения.
# .env находится в .gitignore и не должен попадать в репозиторий.

# --- Общие ---
PROJECT_NAME=Kinescope TMS
ENV=development                    # development | staging | production
LOG_LEVEL=INFO

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# CORS: список разрешённых origin'ов через запятую
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Аутентификация ---
# Корпоративный домен, по которому разрешена регистрация
ALLOWED_EMAIL_DOMAIN=kinescope.io
# Секрет для подписи JWT — обязательно сгенерируйте свой:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-please-generate-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kinescope_tms
POSTGRES_USER=tms
POSTGRES_PASSWORD=tms
# Полный URL для асинхронного драйвера asyncpg
DATABASE_URL=postgresql+asyncpg://tms:tms@postgres:5432/kinescope_tms

# --- Frontend ---
# Куда фронт будет ходить за API. В dev через docker-compose проксирует Vite.
VITE_API_URL=http://localhost:8000

# --- Kaiten (зарезервировано на будущее) ---
KAITEN_BASE_URL=
KAITEN_API_TOKEN=
